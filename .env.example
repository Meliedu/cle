# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/langassistant

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://api.clerk.com/v1/jwks
# Expected `iss` (issuer) claim on Clerk JWTs. Required in production.
# Typically your Clerk Frontend API URL, e.g. https://clerk.yourdomain.com
# or https://<slug>.clerk.accounts.dev for Clerk-hosted frontends.
CLERK_ISSUER=https://<your-frontend-api>.clerk.accounts.dev
# Expected `aud` (audience) claim. Required in production. Set this to match
# the `aud` configured on the Clerk JWT template named "backend".
CLERK_AUDIENCE=meli-backend
# Comma-separated allowlist of authorized parties (`azp` claim) — frontend
# origins permitted to present tokens to this backend. Empty accepts any azp
# (logged as a warning in production).
CLERK_ALLOWED_AZP=http://localhost:3000

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=langassistant-files
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# OpenAI (Embeddings + Whisper)
OPENAI_API_KEY=sk-...

# OpenRouter (LLM)
OPENROUTER_API_KEY=
OPENROUTER_PRIMARY_MODEL=qwen/qwen3.6-plus:free
OPENROUTER_FALLBACK_MODEL=google/gemini-2.5-flash-lite

# App
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_EMAIL_DOMAINS=connect.ust.hk,ust.hk
MAX_UPLOAD_SIZE_MB=100
STUDENT_RATE_LIMIT=10
INSTRUCTOR_RATE_LIMIT=50

# Symmetric encryption for stored third-party tokens (Canvas, etc.)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATIONS_ENCRYPTION_KEY=

# Comma-separated allowlist of permitted Canvas LMS hostnames (SSRF defense)
# Example: canvas.ust.hk,hkust.instructure.com
CANVAS_ALLOWED_HOSTS=

# Canvas OAuth 2.0 (Phase 1) — requires HKUST-issued Developer Key
CANVAS_CLIENT_ID=
CANVAS_CLIENT_SECRET=
CANVAS_BASE_URL=https://canvas.ust.hk
CANVAS_REDIRECT_URI=http://localhost:8000/api/canvas/oauth/callback
# Signing key for OAuth state JWT (32+ random bytes)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
CANVAS_STATE_SECRET=
