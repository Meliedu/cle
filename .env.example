# Database
# Production: use the meli_app role (created by alembic migration
# 6eb0c6b144eb) so RLS policies are enforced — the default postgres
# superuser bypasses RLS silently.
# Example: DATABASE_URL=postgresql+asyncpg://meli_app:<password>@db/langassistant
# Set the password out of band: ALTER ROLE meli_app PASSWORD '<strong>';
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/langassistant

# Better Auth — JWT plugin exposes JWKS at /api/auth/jwks on the Next.js app.
# Production: set to your deployed frontend host, e.g.
#   https://meli.example.com/api/auth/jwks
BETTER_AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks
BETTER_AUTH_ISSUER=http://localhost:3000
BETTER_AUTH_AUDIENCE=meli-backend
# Shared secret for the Better-Auth → backend `users` link endpoint
# (Better Auth signup hook → POST /api/internal/users/link).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
BETTER_AUTH_INTERNAL_SECRET=

# Resend (transactional email — verification + password reset)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Meli <noreply@meli.app>

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=langassistant-files
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# OpenAI (Embeddings + Whisper)
OPENAI_API_KEY=sk-...

# OpenRouter (LLM)
OPENROUTER_API_KEY=
OPENROUTER_PRIMARY_MODEL=qwen/qwen3.6-plus:free
OPENROUTER_FALLBACK_MODEL=google/gemini-2.5-flash-lite

# App
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_EMAIL_DOMAINS=connect.ust.hk,ust.hk
MAX_UPLOAD_SIZE_MB=100
STUDENT_RATE_LIMIT=10
INSTRUCTOR_RATE_LIMIT=50

# Symmetric encryption for stored third-party tokens (Canvas, etc.)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATIONS_ENCRYPTION_KEY=

# Comma-separated allowlist of permitted Canvas LMS hostnames (SSRF defense)
# Example: canvas.ust.hk,hkust.instructure.com
CANVAS_ALLOWED_HOSTS=

# Canvas OAuth 2.0 (Phase 1) — requires HKUST-issued Developer Key
CANVAS_CLIENT_ID=
CANVAS_CLIENT_SECRET=
CANVAS_BASE_URL=https://canvas.ust.hk
CANVAS_REDIRECT_URI=http://localhost:8000/api/canvas/oauth/callback
# Signing key for OAuth state JWT (32+ random bytes)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
CANVAS_STATE_SECRET=
