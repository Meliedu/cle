# Frontend (Next.js) environment — copy to `.env.local` and fill in.
# Never commit real secrets; only this example file is tracked.

# --- Better Auth (server) -------------------------------------------------
# Session-signing secret. Required in production (module throws without it).
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Authenticates the @better-auth/infra dash() plugin (/api/auth/dash/*).
# Required in production.
BETTER_AUTH_API_KEY=
# Shared secret for the Better Auth -> FastAPI users-link/delete calls.
# Must match backend BETTER_AUTH_INTERNAL_SECRET.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
BETTER_AUTH_INTERNAL_SECRET=
# Public base URL of this app (used as the OAuth/OIDC redirect origin).
# Defaults to http://localhost:3000 when unset.
BETTER_AUTH_URL=http://localhost:3000
# Postgres for Better Auth's own tables (auth schema). Falls back to
# DATABASE_URL, then to the local default.
BETTER_AUTH_DATABASE_URL=
# FastAPI internal API base (users-link / delete). Defaults to
# http://localhost:8000/api.
INTERNAL_API_URL=http://localhost:8000/api

# --- Microsoft SSO (existing social provider) -----------------------------
# When set, enables the "Continue with Microsoft" button (also gate the UI
# with NEXT_PUBLIC_MICROSOFT_SSO_ENABLED=true).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# HKUST tenant GUID, or "organizations" for any work/school account.
MICROSOFT_TENANT_ID=

# --- HKUST OIDC (Entra ID) — DORMANT until all values are supplied --------
# HKUST runs TWO separate Entra tenants: Staff (@ust.hk) and Student
# (@connect.ust.hk). Each is a distinct OIDC app registration, wired as a
# generic-OAuth provider in src/lib/auth.ts. A provider is only mounted when
# its clientId + clientSecret + discoveryUrl are ALL present, so leaving any
# blank keeps that tenant off with zero behavior change.
#
# VERIFIED callback path (better-auth 1.6.23):
#   ${BETTER_AUTH_URL}/api/auth/oauth2/callback/hkust-staff
#   ${BETTER_AUTH_URL}/api/auth/oauth2/callback/hkust-student
# See docs/oidc-redirect-uris.md for the full ITSO redirect-URI table.
#
# Client secrets arrive from ITSO by email and expire 2028-06-28.

# Staff tenant (c917f3e2-9322-4926-9bb3-daca730413ca), CLE-Meli staff app
# (830c7819-96e7-4fef-af23-407d4b4365ed):
HKUST_STAFF_MELI_CLIENT_ID=
HKUST_STAFF_MELI_CLIENT_SECRET=
HKUST_STAFF_DISCOVERY_URL=

# Student tenant (pending ITSO — GUID/app/secret/discovery TBD):
HKUST_STUDENT_MELI_CLIENT_ID=
HKUST_STUDENT_MELI_CLIENT_SECRET=
HKUST_STUDENT_DISCOVERY_URL=

# --- Public flags (exposed to the browser) --------------------------------
# Backend API base for apiFetch().
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Show the "Continue with Microsoft" button on the sign-in screen.
NEXT_PUBLIC_MICROSOFT_SSO_ENABLED=
# Show the "HKUST Staff" / "HKUST Student" SSO buttons. Set to "enabled" only
# once the matching HKUST_* provider credentials above are in place.
NEXT_PUBLIC_HKUST_SSO=
